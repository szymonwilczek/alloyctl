# SPDX-License-Identifier: GPL-2.0-only
# Editor defaults, complementing .clang-format for C
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h}]
indent_style = tab
indent_size = 8

[{Makefile,*.mk}]
indent_style = tab

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.rst]
indent_style = space
indent_size = 3

[*.md]
trim_trailing_whitespace = false
